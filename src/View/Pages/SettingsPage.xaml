<Page x:Class="WarframeAlerts.View.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WarframeAlerts.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage">
    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{DynamicResource Onest}"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Margin="20">
            <TextBlock Text="{DynamicResource Language}"/>
            <ComboBox Style="{DynamicResource BaseComboBox}"
                      ItemsSource="{Binding LanguageSource}"
                      SelectedIndex="0"
                      SelectedItem="{Binding LanguageSelected}"
                      Margin="0,2,0,8"/>
            <CheckBox Style="{DynamicResource GoldCheckBox}"
                      Content="{DynamicResource InfinitiNotifications}"
                      IsChecked="{Binding IsInfinitiNotifications}"/>
        </StackPanel>

        <Grid Grid.Column="2"
              Margin="20"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom">
            <Popup Style="{DynamicResource MessagePopup}"
                   IsOpen="{Binding ShowSaveMassage}">
                <Border Background="{DynamicResource BackroundBrush}"
                        CornerRadius="10"
                        Padding="5"
                        Margin="10">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Border.RenderTransform>
                    <TextBlock Text="{DynamicResource Saved}"/>
                </Border>
            </Popup>
            <Button Style="{DynamicResource GoldButton}"
                    Command="{Binding SaveCommand}"
                    Content="{DynamicResource Save}"/>
        </Grid>
    </Grid>
</Page>
